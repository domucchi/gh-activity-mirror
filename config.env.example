# gh-activity-mirror configuration.
#
# Copy this file to config.env and fill in the values, or run ./setup.sh
# to have it generated interactively.
#
# config.env is gitignored — your values stay local.

# --- Accounts ------------------------------------------------------------

# The GitHub account whose activity you want to mirror (the "source").
# Usually your work/org account. Its private contributions are only visible
# to the viewer who owns them, which is why the script auth-switches to it.
WORK_USER="your-work-username"

# The GitHub account that will receive the mirrored commits (the "target").
# Usually your personal account. Must also be signed into `gh`.
PERSONAL_USER="your-personal-username"

# The private repo on PERSONAL_USER that will hold the mirrored empty commits.
# Create it ahead of time (the setup script does this for you), e.g.:
#   gh repo create activity-mirror --private --clone=false
MIRROR_REPO="your-personal-username/activity-mirror"

# --- Commit authorship ---------------------------------------------------

# Email used as the commit author. MUST be verified on PERSONAL_USER or the
# commits will not count toward the contribution graph. Safest option is the
# GitHub noreply address:
#   <id>+<login>@users.noreply.github.com
# Get it by running, while authenticated as PERSONAL_USER:
#   gh api user --jq '"\(.id)+\(.login)@users.noreply.github.com"'
PERSONAL_EMAIL="id+your-personal-username@users.noreply.github.com"

# Display name for the commits. Can be anything; conventionally your GitHub login.
PERSONAL_NAME="your-personal-username"
